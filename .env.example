# === Database ===
POSTGRES_USER=planquest
POSTGRES_PASSWORD=planquest_secret
POSTGRES_DB=planquest
DATABASE_URL=postgresql+asyncpg://planquest:planquest_secret@postgres:5432/planquest

# === Redis ===
